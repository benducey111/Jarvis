# Jarvis environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# OpenAI API key (required if ai.backend = "openai" in settings.yaml)
OPENAI_API_KEY=sk-...your-key-here...

# Optional: override nested config values using double-underscore notation
# AI__MODEL=gpt-4o
# AI__BACKEND=ollama
